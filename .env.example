# bx-AISentinel Demo — Environment
# Copy this file to `.env` and fill in real values. `.env` is git-ignored.

# ─── OpenRouter ──────────────────────────────────────────────────────────
# Your OpenRouter API key. Create one at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-REPLACE_ME

# Default model slug. This demo uses openrouter/elephant-alpha (free tier,
# 256K context, tool-call capable). See https://openrouter.ai/models for the
# full list. Change this and restart the server to swap models.
#
# IMPORTANT: openrouter/elephant-alpha explicitly retains prompts and
# completions for training. That is precisely the scenario bx-AISentinel
# is designed for — it keeps your secrets out of that corpus.
OPENROUTER_MODEL=openrouter/elephant-alpha

# Optional OpenRouter attribution headers (recommended but not required).
OPENROUTER_SITE_URL=http://localhost:8888
OPENROUTER_APP_NAME=bx-AISentinel Demo

# ─── Sentinel policy overrides (optional) ────────────────────────────────
# Leave empty to use the built-in defaults from bx-aisentinel.
# SENTINEL_MANIFEST_SCOPE=conversation
# SENTINEL_ENTROPY_THRESHOLD=4.5
